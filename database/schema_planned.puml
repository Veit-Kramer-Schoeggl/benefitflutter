@startuml schema_planned

!define primary_key(x) <u>x</u>
!define foreign_key(x) <i>x</i>
!define not_null(x) <b>x</b>

title BeneFit Movement Tracking App - COMPLETE DATABASE SCHEMA\n(Implemented + Planned) - Last updated: 2025-02-24

' Color coding for implementation status
skinparam class {
  BackgroundColor<<implemented>> #90EE90
  BackgroundColor<<planned>> #FFE4B5
}

' ==================================================================================
' CORE USER MANAGEMENT (IMPLEMENTED)
' ==================================================================================

entity "users" as users <<implemented>> {
  primary_key(id) : TEXT
  --
  not_null(name) : TEXT
  not_null(email) : TEXT
  not_null(password_hash) : TEXT (SHA-256, v7/v10)
  display_name : TEXT
  gender : TEXT
  date_of_birth : INTEGER (timestamp)
  timezone : TEXT
  profile_image_path : TEXT (v5)
  is_verified : INTEGER (v6)
  verification_status : TEXT (v6)
  not_null(created_at) : INTEGER (timestamp)
  not_null(updated_at) : INTEGER (timestamp)
  --
  <color:gray>' PLANNED EXTENSIONS:</color>
  <color:gray>last_login : INTEGER</color>
  <color:gray>is_active : INTEGER</color>
  <color:gray>verified_at : INTEGER</color>
  <color:gray>data_sharing_consent : INTEGER</color>
  <color:gray>analytics_consent : INTEGER</color>
}

' ==================================================================================
' SESSION MANAGEMENT (IMPLEMENTED)
' ==================================================================================

entity "sessions" as sessions <<implemented>> {
  primary_key(id) : TEXT
  --
  foreign_key(not_null(user_id)) : TEXT
  not_null(tracking_mode) : TEXT
  not_null(activity_type) : TEXT
  not_null(status) : TEXT
  not_null(start_time) : INTEGER (timestamp)
  end_time : INTEGER (timestamp)
  duration_seconds : INTEGER
  distance_meters : REAL
  tracking_date : INTEGER (timestamp)
  not_null(created_at) : INTEGER (timestamp)
  not_null(updated_at) : INTEGER (timestamp)
  --
  ' Wearable data (v4)
  avg_heart_rate : INTEGER
  max_heart_rate : INTEGER
  min_heart_rate : INTEGER
  avg_heart_rate_variability : REAL
  total_steps : INTEGER
  avg_cadence : REAL
  calories_burned : REAL
  heart_rate_zones : TEXT (JSON)
  has_wearable_data : INTEGER
  connected_device_ids : TEXT (JSON)
  --
  <color:gray>' PLANNED EXTENSIONS:</color>
  <color:gray>current_pace_seconds_per_km : INTEGER</color>
  <color:gray>privacy_level : TEXT</color>
  <color:gray>processing_skipped : TEXT (JSON)</color>
}

entity "gps_points" as gps_points <<implemented>> {
  primary_key(id) : TEXT
  --
  foreign_key(not_null(session_id)) : TEXT
  not_null(latitude) : REAL
  not_null(longitude) : REAL
  altitude : REAL
  accuracy_meters : REAL
  speed_meters_per_second : REAL
  not_null(timestamp) : INTEGER (timestamp)
  not_null(created_at) : INTEGER (timestamp)
}

